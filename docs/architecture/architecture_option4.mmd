        end

        subgraph SUP["Supporting Services"]
            direction LR
            SecretMgr["🟢 Secret Manager\n**API Keys**\nDB Secrets"]
            CloudStorage["🟠 Cloud Storage\n**Files · Outputs**\nIntermediate Results"]
